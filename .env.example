# === Stockcard DB Configuration ===
# เลือกโหมดการเชื่อมต่อ DB ตามสถานที่ใช้งาน:
#
# 🏠 โหมด Local (ใช้ในออฟฟิศ / เครื่อง Server ตรง)
#   INVENTORY_DB_HOST=localhost
#   INVENTORY_DB_PORT=5432
#
# 🌐 โหมด Cloudflare Tunnel (ใช้จากภายนอก / ทีมทำงานระยะไกล)
#   INVENTORY_DB_HOST=localhost
#   INVENTORY_DB_PORT=15432
#   (ต้องรัน cloudflared tunnel ก่อน: cloudflared access tcp --hostname db.yourdomain.com --url localhost:15432)
#
# 🧪 โหมด Test DB
#   INVENTORY_DB_HOST=localhost
#   INVENTORY_DB_PORT=15432
#   INVENTORY_DB_NAME=pddoc_dev

INVENTORY_DB_HOST=localhost
INVENTORY_DB_PORT=5432
INVENTORY_DB_USER=postgres
INVENTORY_DB_PASSWORD=postgres123
INVENTORY_DB_NAME=inventory_rm_tan
PORT=3001
