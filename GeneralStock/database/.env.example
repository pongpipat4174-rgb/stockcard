# ⚠️ ต้องใช้ค่าเดียวกับ stockcard/.env และ database/.env

# --- Local (เครื่องเดียวกับ DB) ---
# INVENTORY_DB_PORT=5432
# INVENTORY_DB_NAME=inventory_rm_tan

# --- Cloudflare Tunnel (ทีม dev) ---
# INVENTORY_DB_PORT=15432
# INVENTORY_DB_NAME=inventory_rm_tan

# --- เทส (pddoc_dev) ---
# INVENTORY_DB_PORT=15432
# INVENTORY_DB_NAME=pddoc_dev

INVENTORY_DB_HOST=localhost
INVENTORY_DB_PORT=5432
INVENTORY_DB_NAME=inventory_rm_tan
INVENTORY_DB_USER=postgres
INVENTORY_DB_PASSWORD=postgres123

# Server
PORT=3001

# Google Sheet Sync (backup)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
